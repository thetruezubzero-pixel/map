{
  "type": "record",
  "name": "BusinessRegistration",
  "namespace": "os.aether.streaming",
  "doc": "aether.business_registrations -- new SEC EDGAR filings, OpenCorporates registration deltas. Company records only, see CLAUDE.md.",
  "fields": [
    { "name": "event_id", "type": "string" },
    { "name": "source", "type": "string" },
    { "name": "company_name", "type": "string" },
    { "name": "cik", "type": ["null", "string"], "default": null },
    { "name": "opencorporates_id", "type": ["null", "string"], "default": null },
    { "name": "filing_type", "type": ["null", "string"], "default": null, "doc": "10-K, 10-Q, 8-K, 4, or null for a registration-only event" },
    { "name": "jurisdiction", "type": ["null", "string"], "default": null },
    { "name": "url", "type": ["null", "string"], "default": null },
    { "name": "detected_at", "type": "string" },
    { "name": "license", "type": ["null", "string"], "default": null },
    { "name": "metadata_json", "type": "string", "default": "{}" }
  ]
}
