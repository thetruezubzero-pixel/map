# Environment variables read directly by the Airflow DAGs under
# data/pipelines/dags/ (via os.environ.get/os.getenv). No .env.example
# existed for this directory before a "connect the dots" audit found the
# gap -- docker-compose.yml's `airflow` service is the actual place these
# get wired in for local dev; this file exists so a standalone Airflow
# deployment (outside docker-compose) has something to copy from too.

# Shared Postgres connection for DAGs that write into the gateway's schema
# (osm_ingestion, entity_resolution, elasticsearch_sync,
# agent_weight_decay, and every boundary/census/zoning/gtfs DAG via
# common/db.py). Safe local-dev default matches docker-compose.yml.
GATEWAY_DATABASE_URL=postgres://aether:aether@postgres:5432/aether

# OSM ingestion (osm_ingestion_dag.py) -- Nominatim's usage policy requires
# a real, identifying contact; a generic placeholder domain gets blocked
# by their abuse filters, same requirement as apps/gateway/.env.example's
# NOMINATIM_USER_AGENT.
NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org
NOMINATIM_USER_AGENT=AetherSovereignOS-Airflow/0.2 (contact: ops@yourdomain.org)

# NewsAPI/OpenCorporates ingestion -- both DAGs fail soft (log + skip that
# source) when unset, so these are optional, not required.
NEWSAPI_KEY=
OPENCORPORATES_API_KEY=

# SEC EDGAR ingestion (sec_edgar_ingestion_dag.py) -- EdgarTools refuses to
# run without a real identity (SEC blocks unidentified traffic); the DAG
# fails soft (returns no records, doesn't crash) when unset.
EDGAR_IDENTITY=

# NOAA alerts (noaa_alerts_dag.py) -- has a working built-in default; only
# set this if you want a different identifying contact string.
NOAA_NWS_USER_AGENT=AetherSovereignOS/0.2 (contact: ops@yourdomain.org)

# GTFS transit ingestion (gtfs_transit_dag.py) -- has a working built-in
# default; only set this if you want a different identifying contact
# string.
GTFS_USER_AGENT=AetherSovereignOS-Airflow/0.2 (public-records research tool; set GTFS_USER_AGENT)

# The Architect's daily cycle (project_architect_cycle_dag.py) -- calls
# POST /architect/run on python-api, which verifies this same secret
# itself (see apps/api/python/.env.example, apps/gateway/.env.example).
# Must match those two exactly, or the DAG mints a token python-api will
# reject. Unset means the DAG fails soft ({"skipped": "JWT_SECRET not
# set"}) rather than crashing, but the daily cycle silently never runs.
JWT_SECRET=
PYTHON_API_BASE_URL=http://python-api:8000
