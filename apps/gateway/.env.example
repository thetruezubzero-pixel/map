GATEWAY_BIND_ADDR=0.0.0.0:8080
DATABASE_URL=postgres://aether:aether@postgres:5432/aether
ALLOWED_ORIGINS=http://localhost:5173
NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org
# Nominatim's usage policy requires a real, identifying contact -- generic
# placeholder domains (e.g. example.com) get blocked by their abuse filters.
NOMINATIM_USER_AGENT=AetherSovereignOS/0.2 (contact: ops@yourdomain.org)
NOMINATIM_API_KEY=
# Fallback geocoder if Nominatim errors/blocks (confirmed live: it 403s
# requests from some shared/sandboxed egress IPs regardless of
# User-Agent) -- a separate, independently-run keyless public instance
# over the same OSM data. Default is the public https://photon.komoot.io
# instance; point this at a self-hosted one if you run your own.
PHOTON_BASE_URL=https://photon.komoot.io/api
JWT_SECRET=change-me-in-production
PYTHON_API_BASE_URL=http://python-api:8000
RATE_LIMIT_BURST=10
RATE_LIMIT_PER_SEC=1
AUTHED_RATE_LIMIT_PER_SEC=5
# A readiness review found the outbound HTTP client (Nominatim/Photon/
# python-api calls) and the router itself had no timeout at all -- a
# hung upstream could otherwise hold a request open indefinitely.
# REQUEST_TIMEOUT_SECS does not apply to /ws/alerts (a WebSocket
# connection is meant to stay open indefinitely).
HTTP_CLIENT_TIMEOUT_SECS=10
REQUEST_TIMEOUT_SECS=30
# Max total concurrent /ws/alerts WebSocket connections process-wide.
# Each holds a dedicated Postgres LISTEN connection for its lifetime, so
# this bounds how many a client can open before /ws/alerts returns 503.
WS_ALERTS_MAX_CONNECTIONS=50

# Phase 4 streaming -- used by /health/streaming (Kafka topic/partition
# stats via rdkafka, Flink job overview via its REST API, ksqlDB/Schema
# Registry reachability). See streaming/README.md.
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
SCHEMA_REGISTRY_URL=http://schema-registry:8082
KSQLDB_URL=http://ksqldb:8088
FLINK_REST_URL=http://flink-jobmanager:8081
