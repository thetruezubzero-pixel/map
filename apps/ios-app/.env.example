# Aether Sovereign OS iOS App Configuration

# Backend API endpoints
API_BASE_URL=http://localhost:8000
PYTHON_API_URL=http://localhost:8001
GATEWAY_URL=http://localhost:3000

# For production:
# API_BASE_URL=https://api.aethersovereign.app
# PYTHON_API_URL=https://api.aethersovereign.app/py-api
# GATEWAY_URL=https://api.aethersovereign.app

# Mapbox map styling and tiles
MAPBOX_ACCESS_TOKEN=pk_test_your_mapbox_token_here

# OpenRouter API for LLM calls (optional)
# If set, enables AI-powered research via chat interface
OPENROUTER_API_KEY=sk-or-your_openrouter_key

# App Store configuration (iOS)
DEVELOPMENT_TEAM=ABC123DEFG
PROVISIONING_PROFILE_SPECIFIER=YourProvisioningProfile

# Firebase (optional, for crash reporting)
FIREBASE_PROJECT_ID=your-firebase-project
GOOGLE_APP_ID=your-google-app-id
GOOGLE_API_KEY=your-google-api-key

# Feature flags
DEBUG_MODE=false
ENABLE_NETWORK_LOGGING=false
ENABLE_LOCATION_LOGGING=false
