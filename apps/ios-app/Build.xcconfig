// Build configuration for Aether Sovereign OS iOS app

// Target deployment version (iOS 14.0+)
IPHONEOS_DEPLOYMENT_TARGET = 14.0
TVOS_DEPLOYMENT_TARGET = 14.0

// Minimum OS versions
MACOSX_DEPLOYMENT_TARGET = 10.15
WATCHOS_DEPLOYMENT_TARGET = 7.0

// Code signing
CODE_SIGN_IDENTITY = iPhone Developer
PROVISIONING_PROFILE_SPECIFIER =
SIGNING_CERTIFICATE_FILE_PATH =
DEVELOPMENT_TEAM =

// App bundle
PRODUCT_BUNDLE_IDENTIFIER = com.aethersovereign.map
PRODUCT_NAME = Aether Sovereign OS

// Versioning
MARKETING_VERSION = 1.0.0
CURRENT_PROJECT_VERSION = 1

// Build paths
CONFIGURATION_BUILD_DIR = $(BUILD_DIR)/$(CONFIGURATION)$(EFFECTIVE_PLATFORM_NAME)
SYMROOT = $(SRCROOT)/build
OBJROOT = $(SRCROOT)/build

// Swift settings
SWIFT_VERSION = 5.9
SWIFT_LANGUAGE_VERSION = 5.9
SWIFT_OBJC_BRIDGING_HEADER =

// Optimization
SWIFT_OPTIMIZATION_LEVEL = -O
GCC_OPTIMIZATION_LEVEL = s
ENABLE_BITCODE = YES

// Warnings
GCC_WARN_ABOUT_DEPRECATED_FUNCTIONS = YES
GCC_WARN_MISSING_PARENTHESES = YES
GCC_WARN_NON_VIRTUAL_DESTRUCTOR = YES

// Security
CLANG_ENABLE_CODE_COVERAGE = NO
ENABLE_HARDENED_RUNTIME = YES
ENABLE_BITCODE = YES

// Networking
SUPPORTS_MACCATALYST = NO

// Architecture
VALID_ARCHS = arm64 arm64e

// App Transport Security
REQUIRES_HTTPS = YES
ALLOWS_ARBITRARY_LOADS = NO

// Capabilities
ENTITLEMENTS_FILE = Entitlements.plist

// Localization
DEVELOPMENT_LANGUAGE = en
SUPPORTED_PLATFORMS = iphoneos
