# Podfile for Aether Sovereign OS iOS App

platform :ios, '14.0'

target 'AetherSovereignOS' do
  # Use frameworks for faster builds
  use_frameworks!

  # Network & HTTP
  pod 'Alamofire', '~> 5.9'
  pod 'Moya/RxSwift', '~> 15.0'

  # JSON handling
  pod 'SwiftyJSON', '~> 5.0'

  # Image caching & display
  pod 'Kingfisher', '~> 7.0'

  # WebSocket support
  pod 'Starscream', '~> 4.0'

  # Reactive programming
  pod 'RxSwift', '~> 6.0'
  pod 'RxCocoa', '~> 6.0'
  pod 'RxDataSources', '~> 5.0'

  # Geospatial & Mapping
  pod 'MapboxMaps', '~> 11.0'

  # Database & Local storage
  pod 'Realm', '~> 10.0'

  # Authentication & Security
  pod 'JWT', '~> 3.1'
  pod 'Keychain', '~> 1.1'

  # Networking state
  pod 'Reachability', '~> 3.0'

  # Logging & debugging
  pod 'Hansel', '~> 1.0'

  # UI Components
  pod 'SnapKit', '~> 5.6'

  # Analytics (optional, privacy-focused)
  pod 'Firebase/Analytics', '~> 10.0'
  pod 'Firebase/Crashlytics', '~> 10.0'

  target 'AetherSovereignOSTests' do
    inherit! :search_paths

    # Testing dependencies
    pod 'Quick', '~> 7.0'
    pod 'Nimble', '~> 12.0'
    pod 'Alamofire', '~> 5.9'
    pod 'OHHTTPStubs/Swift', '~> 9.1'
  end
end

# Post-install script for pod configuration
post_install do |installer|
  installer.pods_project.targets.each do |target|
    # Enable optimization for release builds
    flutter_post_install(installer)

    # Suppress warnings for Pods
    target.build_configurations.each do |config|
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '14.0'
      config.build_settings['GCC_WARN_INHIBIT_ALL_WARNINGS'] = 'YES'
    end
  end
end
