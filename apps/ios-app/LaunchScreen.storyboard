                            <constraint firstItem="branding" firstAttribute="centerY" secondItem="Ze5-6b-2t3" secondAttribute="centerY" id="branding-centerY"/>
                            <!-- Loading spinner below branding -->
                            <constraint firstItem="loadingSpinner" firstAttribute="centerX" secondItem="Ze5-6b-2t3" secondAttribute="centerX" id="spinner-centerX"/>
                            <constraint firstItem="loadingSpinner" firstAttribute="top" secondItem="branding" secondAttribute="bottom" constant="40" id="spinner-top"/>
                            <!-- Tagline at bottom -->
                            <constraint firstItem="tagline" firstAttribute="centerX" secondItem="Ze5-6b-2t3" secondAttribute="centerX" id="tagline-centerX"/>
                            <constraint firstItem="tagline" firstAttribute="bottom" secondItem="6Tk-OE-BBY" secondAttribute="bottom" constant="-60" id="tagline-bottom"/>
                            <constraint firstItem="tagline" firstAttribute="leading" secondItem="6Tk-OE-BBY" secondAttribute="leading" constant="20" id="tagline-leading"/>
                            <constraint firstItem="tagline" firstAttribute="trailing" secondItem="6Tk-OE-BBY" secondAttribute="trailing" constant="-20" id="tagline-trailing"/>
