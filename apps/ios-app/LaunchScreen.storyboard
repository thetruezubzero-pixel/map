<?xml version="1.0" encoding="UTF-8"?>
<document type="com.apple.InterfaceBuilder3.CocoaTouch.Storyboard.XIB" version="3.0" toolsVersion="22.0" targetRuntime="iOS.CocoaTouch" propertyAccessControl="none" useAutolayout="YES" launchScreen="YES" useTraitCollections="YES" useSafeAreaLayoutGuide="YES" colorAppearanceEnabled="NO">
    <device id="retina6_1" orientation="portrait" appearance="light"/>
    <device id="retina4_7" orientation="portrait" appearance="light"/>
    <device id="ipad" orientation="portrait" appearance="light"/>
    <dependencies>
