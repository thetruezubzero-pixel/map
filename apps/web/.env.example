VITE_MAPBOX_ACCESS_TOKEN=
# Client-side base paths (relative -- proxied by nginx in prod, by Vite dev server locally)
VITE_GATEWAY_URL=/api
VITE_PY_API_URL=/py-api
# Dev-server-only: where the Vite proxy above forwards those paths to.
# Not read by the browser, only by vite.config.ts.
GATEWAY_PROXY_TARGET=http://localhost:8080
PY_API_PROXY_TARGET=http://localhost:8000
