DATABASE_URL=postgres://aether:aether@postgres:5432/aether
BIND_HOST=0.0.0.0
BIND_PORT=8000
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080

OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_DEFAULT_MODEL=anthropic/claude-3.5-sonnet
OPENROUTER_FAST_MODEL=anthropic/claude-3.5-haiku
OPENROUTER_FALLBACK_MODEL=openai/gpt-4o

NEWSAPI_KEY=
OPENCORPORATES_API_KEY=
NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org

REDIS_URL=redis://redis:6379/0
REDIS_PASSWORD=
REDIS_LANGCACHE_ENABLED=true
REDIS_SEMANTIC_THRESHOLD=0.92

QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=aether_entities

ELASTICSEARCH_URL=http://elasticsearch:9200
ELASTICSEARCH_USERNAME=
ELASTICSEARCH_PASSWORD=
ELASTICSEARCH_API_KEY=

# Required for heirloom export/import (AES-256-GCM). Must be exactly a
# 64-character hex string (32 bytes). Generate one with:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
HEIRLOOM_DEVICE_KEY=

# The Architect (Phase 5b, /architect) -- see ROADMAP.md "Phase 5b: the
# Architect". JWT_SECRET must match the gateway's -- POST /architect/run
# verifies it directly. PROJECT_ROOT must point at a real git working
# tree (docker-compose bind-mounts the repo itself; a standalone run
# needs this pointed at a real local clone) for introspection and the
# commit/PR pipeline to work. GITHUB_TOKEN unset means the commit/PR
# step no-ops with a clear logged reason; snapshotting/planning still
# work.
JWT_SECRET=
PROJECT_ROOT=/repo
GITHUB_TOKEN=
GITHUB_REPO=thetruezubzero-pixel/map
ARCHITECT_AUTO_COMMIT_ENABLED=true

# Phase 5c (/architect) -- see ROADMAP.md "Phase 5c: widening
# safe_to_autoimplement". AGENT_AUTO_MERGE_ENABLED is a separate kill
# switch, default off: the Architect can still propose allowlisted
# documentation changes as PRs either way, but they only auto-merge
# (via the GitHub API, never a direct push) when this is explicitly
# true AND confidence * agent_registry.current_weight clears the
# threshold below.
AGENT_AUTO_MERGE_ENABLED=false
AGENT_AUTO_MERGE_CONFIDENCE_THRESHOLD=0.9
# A brand-new agent's current_weight starts at 1.0 (the neutral prior,
# not an earned track record) -- this requires that many completed
# cycles first, so a single high self-reported confidence on an agent's
# very first run can't clear the auto-merge gate alone.
AGENT_AUTO_MERGE_MIN_TRACK_RECORD=10
