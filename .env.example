# Root-level env for `docker compose up`. Each app also has its own
# .env.example (apps/gateway, apps/web, apps/api/python) for standalone runs.

# Nominatim's usage policy requires a real, identifying contact -- generic
# placeholder domains (e.g. example.com) get blocked by their abuse filters.
NOMINATIM_USER_AGENT=AetherSovereignOS/0.2 (contact: ops@yourdomain.org)

JWT_SECRET=change-me-in-production

# Required for the AI research/agent system (POST /research, the /swarm
# dashboard) to actually work -- without it, those requests reach
# OpenRouter with a blank auth header and fail with a real 401. The map,
# search, and entity browsing all work fine without this. OpenRouter is
# not free -- needs an account with funded credits, unlike Mapbox below.
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_DEFAULT_MODEL=anthropic/claude-3.5-sonnet
OPENROUTER_FAST_MODEL=anthropic/claude-3.5-haiku
OPENROUTER_FALLBACK_MODEL=openai/gpt-4o

# Both fully optional -- research agents just skip that data source if
# unset (see app/agents/data_retriever.py), no error either way.
NEWSAPI_KEY=
OPENCORPORATES_API_KEY=

REDIS_PASSWORD=aether

# Optional but recommended -- without it, the map panel shows a
# "set your token" placeholder instead of an actual map. Free tokens at
# https://account.mapbox.com/access-tokens/
VITE_MAPBOX_ACCESS_TOKEN=
