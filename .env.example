# Copy to .env and fill in values. Never commit the real .env file.

# --- Postgres / PostGIS (infra/docker/docker-compose.yml) ---
POSTGRES_USER=aether
POSTGRES_PASSWORD=change-me
POSTGRES_DB=aether

# --- Gateway (apps/api/rust/gateway) ---
PORT=8080

# Nominatim (OpenStreetMap) geocoding. Free public instance by default;
# point at your own instance if you have one.
NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org
# Nominatim's usage policy asks for a contact email on requests.
OPERATOR_CONTACT=

# Comma-separated list of allowed browser origins for CORS. Empty = no
# cross-origin browser access permitted.
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Rate limiting (tower_governor) applied per client IP.
RATE_LIMIT_PER_SECOND=2
RATE_LIMIT_BURST=10

# Comma-separated, case-insensitive substrings of User-Agent to block.
BOT_BLOCKLIST=
